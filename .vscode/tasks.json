{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "coordinator-build",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "--bin=coordinator",
        "--package=coordinator",
        "--release"
      ],
      "cwd": "${workspaceFolder}",
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "mpc-node-build",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "--bin=mpc-node",
        "--package=mpc-node",
        "--release"
      ],
      "cwd": "${workspaceFolder}",
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "frontend-dev-server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "cwd": "${workspaceFolder}/app",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*ready.*",
          "endsPattern": "^.*compiled.*"
        }
      }
    },
    {
      "label": "terminate-frontend-server",
      "type": "shell",
      "command": "pkill",
      "args": ["-f", "npm.*run.*dev"],
      "isBackground": false
    },
    {
      "label": "docker-compose-up",
      "type": "shell",
      "command": "docker-compose",
      "args": ["up", "-d", "--build"],
      "cwd": "${workspaceFolder}",
      "problemMatcher": []
    },
    {
      "label": "docker-compose-down",
      "type": "shell",
      "command": "docker-compose",
      "args": ["down", "--remove-orphans"],
      "cwd": "${workspaceFolder}",
      "problemMatcher": []
    },
    {
      "label": "cargo-check",
      "type": "shell",
      "command": "cargo",
      "args": ["check", "--workspace"],
      "cwd": "${workspaceFolder}",
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "cargo-test",
      "type": "shell",
      "command": "cargo",
      "args": ["test", "--workspace"],
      "cwd": "${workspaceFolder}",
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
